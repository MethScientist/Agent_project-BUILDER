from planner.planner import Planner
from executor.step_executor import StepExecutor
from memory.memory_manager import MemoryManager
from config.settings import SETTINGS
from utils.logger import log_info

def main():
    log_info("🧠 AI Agent Starting...")
    memory = MemoryManager()
    planner = Planner(memory)
    executor = StepExecutor(memory)

    user_prompt = input("💬 Your Prompt: ")
    plan = planner.create_plan(user_prompt)
    memory.save_plan(plan)

    for step in plan:
        if not memory.is_step_done(step):
            log_info(f"🚧 Executing Step: {step['description']}")
            executor.execute_step(step)
            memory.mark_step_done(step)

    log_info("✅ All steps executed.")

if __name__ == "__main__":
    main()
