@@ -0,0 +1,10 @@
+export function titleCase(s: string): string {
+  if (!s) return "";
+  return s
+    .split(/\s+/)
+    .map(word => {
+      if (!word) return "";
+      return word[0].toUpperCase() + word.slice(1).toLowerCase();
+    })
+    .join(" ");
+}